{
  "manifest_version": 3,
  "name": "Lumiq",
  "version": "2.0",
  "description": "AI superpowers for any text on the web. Explain, summarize, translate, simplify and more — instantly.",
  "permissions": ["activeTab", "scripting", "storage", "contextMenus"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "css": ["styles.css"],
    "run_at": "document_idle"
  }],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "explain-selection":   { "suggested_key": { "default": "Ctrl+Shift+E", "mac": "Command+Shift+E" }, "description": "Explain selected text" },
    "summarize-selection": { "suggested_key": { "default": "Ctrl+Shift+S", "mac": "Command+Shift+S" }, "description": "Summarize selected text" },
    "explain-page":        { "suggested_key": { "default": "Ctrl+Shift+P", "mac": "Command+Shift+P" }, "description": "Explain current page" }
  }
}
